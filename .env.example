# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5000
API_URL=http://localhost:5000/api

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sanskriti_market?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRE=7d

# Google Gemini AI (free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Razorpay (free at razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Cloudinary (free at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email - Gmail SMTP (free)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Sanskriti Market <your_gmail@gmail.com>

# Admin Seed
ADMIN_EMAIL=admin@sanskritimarket.com
ADMIN_PASSWORD=Admin@123456
